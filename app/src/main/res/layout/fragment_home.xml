<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Welcome Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome!"
                android:textColor="@color/textPrimary"
                android:textSize="32sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Your safety is our priority."
                android:textColor="@color/textSecondary"
                android:textSize="16sp" />

            <!-- SOS Centerpiece -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="20dp">

                <!-- Outer Glow Ring -->
                <View
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_gravity="center"
                    android:background="@drawable/sos_button_background"
                    android:alpha="0.15" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btStartService"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:background="@drawable/sos_button_background"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:text="SOS"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/purple_main"
                    app:cornerRadius="100dp"
                    app:elevation="12dp" />

                <TextView
                    android:id="@+id/tvText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="20dp"
                    android:text="Monitoring Active"
                    android:textColor="@color/success"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Services/Actions Grid -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Safety Services"
                android:textColor="@color/textPrimary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2"
                android:rowCount="1">

                <com.google.android.material.card.MaterialCardView
                    style="@style/FeatureCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/stat_sys_phone_call"
                            app:tint="@color/purple_main" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="SOS Trigger"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/PurpleButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginTop="12dp"
                            android:text="Start"
                            android:textSize="10sp"
                            app:cornerRadius="16dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/FeatureCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="@color/purple_main" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Live Track"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/PurpleButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginTop="12dp"
                            android:text="Active"
                            android:textSize="10sp"
                            app:cornerRadius="16dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- Bottom Toggle Section -->
            <com.google.android.material.card.MaterialCardView
                style="@style/FeatureCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="40dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchVolume"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Volume Button Detection"
                        android:textColor="@color/textPrimary"
                        app:thumbTint="@color/purple_main"
                        app:trackTint="@color/colorPrimaryLight" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="#F0F0F0" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchShake"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Shake &amp; Tap Alert"
                        android:textColor="@color/textPrimary"
                        app:thumbTint="@color/purple_main"
                        app:trackTint="@color/colorPrimaryLight" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
