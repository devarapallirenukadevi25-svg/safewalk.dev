<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Safe Community"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable this to receive SOS alerts from other users within a 1km radius and to broadcast your SOS to them in emergencies."
        android:layout_marginBottom="24dp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchCommunity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Join Safe Radius Community"
        android:textSize="18sp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvCommunityStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Not Joined"
        android:gravity="center"
        android:textStyle="italic" />

</LinearLayout>
